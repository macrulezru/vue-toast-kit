{
  "name": "vue-toast-kit",
  "version": "1.0.1",
  "description": "Ultimate toast notification system for Vue 3 and Nuxt 3",
  "license": "MIT",
  "author": "macrulezru",
  "repository": {
    "type": "git",
    "url": "https://github.com/macrulezru/vue-toast-kit"
  },
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "nuxt3",
    "toast",
    "notification",
    "promise",
    "undo",
    "queue",
    "headless",
    "composable"
  ],
  "type": "module",
  "main": "./dist/vue-toast-kit.cjs",
  "module": "./dist/vue-toast-kit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-toast-kit.js",
      "require": "./dist/vue-toast-kit.cjs",
      "types": "./dist/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt/module.js",
      "require": "./dist/nuxt/module.cjs",
      "types": "./dist/nuxt/module.d.ts"
    },
    "./style": "./dist/style.css",
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "demo": "npm --prefix demo install && npm --prefix demo run dev",
    "demo:dev": "npm --prefix demo run dev",
    "demo:build": "npm --prefix demo run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write src/",
    "lint:style": "stylelint \"src/**/*.{css,scss,vue}\""
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nuxt/kit": "^4.4.6",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "nuxt": "^4.4.5",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.2.0",
    "vue": "^3.4.0"
  }
}
